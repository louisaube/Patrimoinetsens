# =============================================================================
# Variables d'environnement — Patrimoine & Sens
# Copier ce fichier en .env.local et remplir les valeurs.
# NE JAMAIS committer .env.local dans git.
# =============================================================================

# Base de données Neon PostgreSQL
# Obtenir sur console.neon.tech — format : postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Auth.js — secret de chiffrement des JWT
# Générer avec : openssl rand -base64 32
AUTH_SECRET=generate-with-openssl-rand-base64-32

# OAuth Google (optionnel en dev, requis en prod)
# Créer sur console.cloud.google.com
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend — envoi des magic links email
# Obtenir sur resend.com
AUTH_RESEND_KEY=

# Adresse expéditrice des emails d'authentification
EMAIL_FROM=noreply@patrimoine-sens.fr

# OpenAI — transcription audio Whisper (V1.1)
# Obtenir sur platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
